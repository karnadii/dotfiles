{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ffplay -nodisp -autoexit -loglevel quiet /usr/share/sounds/freedesktop/stereo/message.oga"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ffplay -nodisp -autoexit -loglevel quiet /usr/share/sounds/freedesktop/stereo/bell.oga"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ffplay -nodisp -autoexit -loglevel quiet /usr/share/sounds/freedesktop/stereo/complete.oga"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "theme": "custom:andromeda",
  "mcpServers": {
    "dart": {
      "type": "stdio",
      "command": "dart",
      "args": [
        "mcp-server"
      ]
    },
    "calculator": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-calculator"
      ]
    },
    "time": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY"
      }
    }
  }
}