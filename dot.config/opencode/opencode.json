{
  "$schema": "https://opencode.ai/config.json",
  "model": "agentrouter/glm-5.1",
  "small_model": "agentrouter/glm-4.6",
  "mcp": {
    "dart": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server"
      ],
      "enabled": true
    },
    "calculator": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-calculator"
      ],
      "enabled": true
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "env": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY"
      }
    }
  },
  "lsp": {
    "dart": {
      "command": [
        "dart",
        "language-server"
      ],
      "extensions": [
        ".dart"
      ]
    },
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    },
    "eslint": {
      "command": [
        "vscode-eslint-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts",
        ".vue"
      ]
    },
    "gopls": {
      "command": [
        "gopls"
      ],
      "extensions": [
        ".go"
      ]
    },
    "pylsp": {
      "command": [
        "pylsp"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "lsp",
        "stdio"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "vscode-json-language-server": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ]
    },
    "yaml-language-server": {
      "command": [
        "yaml-language-server",
        "--stdio"
      ],
      "extensions": [
        ".yml",
        ".yaml"
      ]
    },
    "marksman": {
      "command": [
        "vscode-markdown-language-server",
        "--stdio"
      ],
      "extensions": [
        ".md",
        ".markdown",
        ".mkd"
      ]
    },
    "bash-language-server": {
      "command": [
        "/home/karnadi/.bun/bin/bash-language-server",
        "start"
      ],
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".bashrc",
        ".bash_profile",
        ".zshrc",
        ".zprofile",
        ".profile",
        ".env"
      ]
    },
    "vscode-html-language-server": {
      "command": [
        "vscode-html-language-server",
        "--stdio"
      ],
      "extensions": [
        ".html",
        ".htm"
      ]
    },
    "vscode-css-language-server": {
      "command": [
        "vscode-css-language-server",
        "--stdio"
      ],
      "extensions": [
        ".css",
        ".scss",
        ".sass"
      ]
    },
    "rust-analyzer": {
      "command": [
        "rust-analyzer"
      ],
      "extensions": [
        ".rs"
      ]
    }
  },
  "formatter": {
    "dart": {
      "command": [
        "dart",
        "format"
      ],
      "extensions": [
        ".dart"
      ]
    },
    "prettier-ts": {
      "command": [
        "prettier",
        "--parser",
        "typescript"
      ],
      "extensions": [
        ".ts"
      ]
    },
    "prettier-tsx": {
      "command": [
        "prettier",
        "--parser",
        "typescript"
      ],
      "extensions": [
        ".tsx"
      ]
    },
    "prettier-js": {
      "command": [
        "prettier",
        "--parser",
        "babel"
      ],
      "extensions": [
        ".js"
      ]
    },
    "prettier-jsx": {
      "command": [
        "prettier",
        "--parser",
        "babel"
      ],
      "extensions": [
        ".jsx"
      ]
    },
    "prettier-json": {
      "command": [
        "prettier",
        "--parser",
        "json"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ]
    },
    "prettier-yaml": {
      "command": [
        "prettier",
        "--parser",
        "yaml"
      ],
      "extensions": [
        ".yml",
        ".yaml"
      ]
    },
    "prettier-html": {
      "command": [
        "prettier",
        "--parser",
        "html"
      ],
      "extensions": [
        ".html",
        ".htm"
      ]
    },
    "prettier-css": {
      "command": [
        "prettier",
        "--parser",
        "css"
      ],
      "extensions": [
        ".css"
      ]
    },
    "prettier-scss": {
      "command": [
        "prettier",
        "--parser",
        "scss"
      ],
      "extensions": [
        ".scss",
        ".sass"
      ]
    },
    "prettier-md": {
      "command": [
        "prettier",
        "--parser",
        "markdown"
      ],
      "extensions": [
        ".md",
        ".markdown"
      ]
    },
    "black": {
      "command": [
        "black",
        "--quiet",
        "--stdin-filename",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "goimports": {
      "command": [
        "goimports",
        "-w"
      ],
      "extensions": [
        ".go"
      ]
    },
    "rustfmt": {
      "command": [
        "rustfmt",
        "--edition",
        "2024"
      ],
      "extensions": [
        ".rs"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "format"
      ],
      "extensions": [
        ".toml"
      ]
    }
  }
}